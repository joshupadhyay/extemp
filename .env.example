# Modal Whisper endpoint URL (from `modal deploy pipeline/transcribe.py`)
# Example: https://your-workspace--extemp-whisper-whisper-transcribe.modal.run
MODAL_ENDPOINT_URL=

# Modal auth (for deploying)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Better Auth
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://extemp.vercel.app

# Supabase (provided by Vercel integration)
DATABASE_URL=

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Callback URL: https://extemp.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — https://github.com/settings/developers
# Callback URL: https://extemp.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
